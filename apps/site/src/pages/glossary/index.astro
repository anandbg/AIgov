---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { getCollection } from 'astro:content';
import { glossaryUrl, withBase } from '@aigov/shared';
const BASE = import.meta.env.BASE_URL;

const terms = (await getCollection('glossary'))
  .filter((g) => !g.id.startsWith('_'))
  .map((g) => g.data)
  .sort((a, b) => a.term.localeCompare(b.term));

const groups = new Map<string, typeof terms>();
for (const t of terms) {
  const letter = t.term[0]?.toUpperCase() ?? '?';
  const arr = groups.get(letter) ?? [];
  arr.push(t);
  groups.set(letter, arr);
}
const sortedGroups = Array.from(groups.entries()).sort(([a], [b]) => a.localeCompare(b));
---
<StarlightPage
  frontmatter={{
    title: 'Glossary',
    description: 'Plain-language definitions for every term used across the AI Governance journey.',
    tableOfContents: false,
  }}
>
  <p>
    Every underlined term on this site has a glossary entry — open a stage page,
    hover any dotted-underline word, and you'll see the short definition. This page
    is the full alphabetical index for searching.
  </p>

  <nav class="glossary-jump" aria-label="Jump to letter">
    {sortedGroups.map(([letter]) => (
      <a href={`#${letter}`}>{letter}</a>
    ))}
  </nav>

  {sortedGroups.map(([letter, items]) => (
    <section class="glossary-group">
      <h2 id={letter}>{letter}</h2>
      <dl>
        {items.map((t) => (
          <>
            <dt><a href={withBase(BASE, glossaryUrl(t.slug))}>{t.term}</a></dt>
            <dd>{t.definition}</dd>
          </>
        ))}
      </dl>
    </section>
  ))}
</StarlightPage>

<style>
  .glossary-jump {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 12px 0 24px;
  }
  .glossary-jump a {
    font-family: var(--font-mono, ui-monospace);
    font-size: 14px;
    padding: 4px 8px;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 4px;
    text-decoration: none;
  }
  .glossary-group dl {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 16px;
    margin: 8px 0 16px;
  }
  .glossary-group dt {
    font-weight: 600;
  }
  .glossary-group dd {
    margin: 0;
    color: var(--sl-color-text);
  }
  .glossary-group h2 {
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 4px;
    scroll-margin-top: 80px;
  }
</style>
