---
interface Props {
  jurisdiction: 'eu' | 'uk' | 'us' | 'apac' | 'global';
}
const { jurisdiction } = Astro.props as Props;
---
<aside data-for-jurisdiction={jurisdiction} class="juris-lens">
  <div class="juris-pill" aria-label={`Jurisdiction: ${jurisdiction.toUpperCase()}`}>
    {jurisdiction.toUpperCase()}
  </div>
  <div class="juris-body"><slot /></div>
</aside>

<style>
  .juris-lens {
    border: 1px solid var(--sl-color-gray-5);
    background: var(--sl-color-bg-sidebar);
    padding: 12px 16px;
    border-radius: 8px;
    margin: 16px 0;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 8px 16px;
    align-items: start;
  }
  .juris-pill {
    grid-column: 2;
    grid-row: 1;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-text);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .juris-body {
    grid-column: 1;
    grid-row: 1 / span 2;
  }
</style>
