---
import { Icon } from 'astro-icon/components';

interface Props {
  variant: 'footer' | 'banner';
  regulationName?: string;
  lastScraped?: string;
}
const { variant, regulationName, lastScraped } = Astro.props as Props;
---
{variant === 'footer' ? (
  <div class="disclaimer-footer">
    This site explains AI governance. It is not legal advice. Consult qualified counsel before acting on any content.
  </div>
) : (
  <div class="disclaimer-banner" data-regulation={regulationName ?? ''}>
    <span class="not-legal-advice-pill">Not legal advice</span>
    {regulationName && <span class="reg-name">{regulationName}</span>}
    {lastScraped && <span class="last-scraped">Last scraped: <code>{lastScraped}</code></span>}
    <button type="button" class="dismiss" aria-label="Dismiss banner">
      <Icon name="lucide:x" />
    </button>
  </div>
)}

{variant === 'banner' && (
  <script>
    (function () {
      const KEY = 'aigov:reg-disclaimer-dismissed';
      const banner = document.querySelector('.disclaimer-banner');
      if (!banner) return;
      const reg = banner.getAttribute('data-regulation') || '';
      try {
        const dismissed = window.sessionStorage.getItem(KEY);
        if (dismissed && dismissed === reg) {
          (banner as HTMLElement).hidden = true;
        }
      } catch {}
      const btn = banner.querySelector('.dismiss');
      btn?.addEventListener('click', () => {
        try { window.sessionStorage.setItem(KEY, reg); } catch {}
        (banner as HTMLElement).hidden = true;
      });
    })();
  </script>
)}

<style>
  .disclaimer-footer {
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-text-muted);
    font-size: 14px;
    padding: 16px;
    border-top: 1px solid var(--sl-color-gray-5);
  }
  .disclaimer-banner {
    position: sticky;
    top: var(--sl-nav-height, 60px);
    z-index: 40;
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--sl-color-bg);
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding: 8px 16px;
    font-size: 14px;
  }
  .not-legal-advice-pill {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    background: var(--sl-color-info-low, #d1ecf1);
    color: var(--sl-color-info-high, #0c5460);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .reg-name {
    font-weight: 600;
    color: var(--sl-color-text);
  }
  .last-scraped {
    color: var(--sl-color-text-muted);
  }
  .last-scraped code {
    font-family: var(--font-mono, ui-monospace);
    font-size: 13px;
  }
  .dismiss {
    margin-left: auto;
    background: none;
    border: 0;
    padding: 6px;
    cursor: pointer;
    color: var(--sl-color-text-muted);
  }
</style>
