---
import { Icon } from 'astro-icon/components';
import { sustainabilityMode, sustainabilityLastReviewedAt } from '~/config/site';
---
{sustainabilityMode && (
  <div role="status" class="sustainability-notice">
    <Icon name="lucide:clock-alert" class="su-icon" />
    <div class="su-body">
      <strong>Maintained at low cadence.</strong>
      <span>Last full review: <code>{sustainabilityLastReviewedAt}</code>. Why? See <a href="/about/#sustainability">About</a>.</span>
    </div>
  </div>
)}

<style>
  .sustainability-notice {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    background: var(--sl-color-warning-low, #fff3cd);
    color: var(--sl-color-warning-high, #664d03);
    border-bottom: 1px solid var(--sl-color-warning, #ffcd39);
    padding: 12px 16px;
    font-size: 14px;
  }
  .sustainability-notice strong { font-weight: 700; margin-right: 6px; }
  .su-icon { flex: 0 0 auto; margin-top: 2px; }
  .su-body { flex: 1; }
  .sustainability-notice a { color: inherit; text-decoration: underline; }
</style>
