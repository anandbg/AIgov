---
import { Icon } from 'astro-icon/components';
---
<div class="persona-switch">
  <div role="tablist" data-persona-tablist aria-label="Persona lens" class="persona-switch-pills">
    <button type="button" role="tab" data-persona-value="exec" aria-controls="main-content" aria-selected="false" class="touch-target">
      <Icon name="lucide:users" />
      <span>Exec</span>
    </button>
    <button type="button" role="tab" data-persona-value="engineer" aria-controls="main-content" aria-selected="false" class="touch-target">
      <Icon name="lucide:code-2" />
      <span>Engineer</span>
    </button>
    <button type="button" role="tab" data-persona-value="compliance" aria-controls="main-content" aria-selected="false" class="touch-target">
      <Icon name="lucide:scale" />
      <span>Compliance</span>
    </button>
  </div>
  <button type="button" data-persona-value="all" class="persona-switch-reset">Reset to all lenses</button>
</div>

<script>
  import '../scripts/persona.client.ts';
</script>

<style>
  .persona-switch {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-start;
    padding: 6px 12px;
  }
  .persona-switch-pills {
    display: inline-flex;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    overflow: hidden;
    background: var(--sl-color-bg);
  }
  .persona-switch-pills button[role="tab"] {
    background: transparent;
    border: 0;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--sl-color-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .persona-switch-pills button[aria-selected="true"] {
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    box-shadow: inset 0 0 0 1px var(--sl-color-accent);
  }
  .persona-switch-pills button[role="tab"]:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }
  .persona-switch-reset {
    background: none;
    border: 0;
    padding: 0;
    color: var(--sl-color-text-muted);
    font-size: 12px;
    text-decoration: underline;
    cursor: pointer;
  }
</style>
