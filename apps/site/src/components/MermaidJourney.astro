---
import { withBase } from '@aigov/shared';
const BASE = import.meta.env.BASE_URL;

interface Props {
  currentStage?: number;
}
const { currentStage } = Astro.props as Props;
const wrapperClass = ['mermaid-journey', currentStage ? `current-S${currentStage}` : ''].filter(Boolean).join(' ');

type Stage = { id: string; label: string; slug: string; phase: number };
type Phase = { num: number; title: string; tagline: string; stages: Stage[] };

const phases: Phase[] = [
  {
    num: 1,
    title: 'Set the rules',
    tagline: 'Decide what your company will — and won’t — do with AI.',
    stages: [
      { id: 'S1', label: '1. AI Policy',    slug: '01-ai-policy',    phase: 1 },
      { id: 'S2', label: '2. Risk Tiering', slug: '02-risk-tiering', phase: 1 },
      { id: 'S3', label: '3. Risk Check',   slug: '03-risk-check',   phase: 1 },
    ],
  },
  {
    num: 2,
    title: 'Make it legal & safe',
    tagline: 'Meet the laws, vet your suppliers, protect your data.',
    stages: [
      { id: 'S4', label: '4. Compliance',          slug: '04-compliance',       phase: 2 },
      { id: 'S5', label: '5. Third-party AI Risk', slug: '05-third-party-risk', phase: 2 },
      { id: 'S6', label: '6. Data Controls',       slug: '06-data-controls',    phase: 2 },
    ],
  },
  {
    num: 3,
    title: 'Prove it works',
    tagline: 'Stress-test the system, write down what you did, name who’s on the hook.',
    stages: [
      { id: 'S7', label: '7. Red-teaming',    slug: '07-red-teaming',    phase: 3 },
      { id: 'S8', label: '8. Documentation',  slug: '08-documentation',  phase: 3 },
      { id: 'S9', label: '9. Accountability', slug: '09-accountability', phase: 3 },
    ],
  },
  {
    num: 4,
    title: 'Run and watch',
    tagline: 'Supervise live AI, handle incidents, keep an eye on it forever.',
    stages: [
      { id: 'S10', label: '10. Agentic Oversight',  slug: '10-agentic-oversight', phase: 4 },
      { id: 'S11', label: '11. Incident Response',  slug: '11-incident-response', phase: 4 },
      { id: 'S12', label: '12. Monitoring',         slug: '12-monitoring',        phase: 4 },
    ],
  },
];

const stages: Stage[] = phases.flatMap((p) => p.stages);
const currentPhase = currentStage ? phases.find((p) => p.stages.some((s) => parseInt(s.id.slice(1), 10) === currentStage))?.num : undefined;

// Multi-row layout: 4 rows of 3 stages, grouped by phase. Renders compact and
// readable instead of a 12-node horizontal sliver. Each phase subgraph flows
// left-to-right; phases connect top-to-bottom so the whole journey reads like
// a board game laid out on a page rather than a single squashed line.
const phaseLines = phases.flatMap((p) => {
  const arrow = p.stages.map((s) => `${s.id}[${s.label}]`).join(' --> ');
  return [
    `  subgraph P${p.num} ["Phase ${p.num} · ${p.title}"]`,
    `    direction LR`,
    `    ${arrow}`,
    `  end`,
  ];
});

const phaseLinks: string[] = [];
for (let i = 0; i < phases.length - 1; i++) {
  const last = phases[i].stages[phases[i].stages.length - 1].id;
  const first = phases[i + 1].stages[0].id;
  phaseLinks.push(`  ${last} --> ${first}`);
}

const styleLines: string[] = [];
if (currentStage) {
  styleLines.push(`  style S${currentStage} fill:#4f46e5,stroke:#312e81,stroke-width:2px,color:#ffffff`);
}
if (currentPhase) {
  styleLines.push(`  style P${currentPhase} fill:#eef2ff,stroke:#6366f1,stroke-width:1.5px`);
}

// Make every stage node a clickable link so the diagram itself is navigable
// (Mermaid's `click` directive renders nodes as <a> elements wrapping the rect).
const clickLines = stages.map((s) => {
  const href = withBase(BASE, `/stages/${s.slug}/`);
  return `  click ${s.id} "${href}" "${s.label}"`;
});

const diagram = [
  'flowchart TB',
  ...phaseLines,
  ...phaseLinks,
  ...styleLines,
  ...clickLines,
].join('\n');
---
<div class={wrapperClass}>
  <pre class="mermaid" data-mermaid-source>{diagram}</pre>

  <details class="mermaid-fallback" open>
    <summary>List view of the 12-stage journey</summary>
    {phases.map((p) => (
      <section class="mermaid-fallback-phase">
        <h4>Phase {p.num} · {p.title}</h4>
        <p class="mermaid-fallback-tagline">{p.tagline}</p>
        <ol>
          {p.stages.map((s) => {
            const n = parseInt(s.id.slice(1), 10);
            const isHere = currentStage === n;
            return (
              <li>
                <a href={withBase(BASE, `/stages/${s.slug}/`)} class={isHere ? 'current' : ''}>{s.label}</a>
                {isHere && <span class="mermaid-here"> ← you are here</span>}
              </li>
            );
          })}
        </ol>
      </section>
    ))}
  </details>
</div>

<script>
  // The astro-mermaid integration already discovers `pre.mermaid` elements and
  // renders them client-side with theme awareness. Running a second renderer
  // (which this component previously did) double-bound the same pre tag,
  // sometimes leaving Mermaid's "Syntax error in text — mermaid version 11.15.0"
  // banner at the bottom of the page. We now defer entirely to astro-mermaid.
  //
  // After astro-mermaid replaces our pre with an SVG it can leave behind a
  // stray sibling error element if a previous render failed mid-way. Sweep
  // any such artefacts so they never reach the reader.
  function sweepStrayMermaidErrors(): void {
    document.querySelectorAll('div.mermaid[data-processed]').forEach((el) => {
      // ok
    });
    document.querySelectorAll('[id^="dmermaid-"], [id^="mermaid-svg-"]').forEach((el) => {
      // mermaid's own scratch nodes shouldn't survive past render
      const parent = el.parentElement;
      if (parent && parent.tagName === 'BODY' && !el.closest('.mermaid-journey')) {
        el.remove();
      }
    });
    // Anything Mermaid printed inline as a fallback error
    document.querySelectorAll('div, pre').forEach((el) => {
      const text = el.textContent ?? '';
      if (/Syntax error in text/.test(text) && /mermaid version/.test(text)) {
        if (!el.closest('.mermaid-journey')) el.remove();
      }
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setTimeout(sweepStrayMermaidErrors, 1500);
    });
  } else {
    setTimeout(sweepStrayMermaidErrors, 1500);
  }
</script>

<style>
  .mermaid-journey {
    container-type: inline-size;
  }
  .mermaid-journey :global(.mermaid) {
    margin: 16px auto;
    text-align: center;
    /* Give the multi-row diagram more vertical room so node text stays readable. */
    min-height: 320px;
  }
  .mermaid-journey :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
    /* The diagram now has 4 rows; ensure phase labels stay legible. */
    font-size: 14px;
  }
  .mermaid-journey :global(.mermaid .cluster rect) {
    rx: 10px;
    ry: 10px;
  }
  .mermaid-journey :global(.mermaid .cluster-label) {
    font-weight: 600;
  }
  pre.mermaid[data-mermaid-source] {
    font-family: var(--font-mono, ui-monospace);
    font-size: 12px;
    color: var(--sl-color-text-muted);
    background: var(--sl-color-bg-sidebar);
    padding: 12px;
    border-radius: 6px;
    overflow-x: auto;
    white-space: pre;
  }
  .mermaid-fallback {
    margin-top: 12px;
    font-size: 14px;
    color: var(--sl-color-text-muted);
  }
  .mermaid-fallback-phase {
    margin-top: 12px;
  }
  .mermaid-fallback-phase h4 {
    margin: 8px 0 2px;
    font-size: 15px;
    color: var(--sl-color-text);
  }
  .mermaid-fallback-tagline {
    margin: 0 0 4px;
    font-size: 13px;
    font-style: italic;
    color: var(--sl-color-text-muted);
  }
  .mermaid-fallback ol { padding-left: 20px; }
  .mermaid-fallback a.current {
    font-weight: 700;
    color: var(--sl-color-accent);
  }
  .mermaid-here {
    color: var(--sl-color-accent);
    font-weight: 600;
  }
</style>
