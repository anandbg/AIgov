---
/* Pure HTML/CSS journey visualisation. Previously rendered via Mermaid +
 * astro-mermaid client-side, but the integration's view-transition re-init
 * was occasionally wiping page content and leaving "Syntax error in text —
 * mermaid version 11.15.0" banners on the screen. A static SSR diagram with
 * no JavaScript has none of those failure modes. */
import { withBase } from '@aigov/shared';
const BASE = import.meta.env.BASE_URL;

interface Props {
  currentStage?: number;
}
const { currentStage } = Astro.props as Props;

type Stage = { id: string; label: string; slug: string; phase: number };
type Phase = { num: number; title: string; tagline: string; stages: Stage[] };

const phases: Phase[] = [
  {
    num: 1,
    title: 'Set the rules',
    tagline: 'Decide what your company will — and won’t — do with AI.',
    stages: [
      { id: 'S1', label: '1. AI Policy',    slug: '01-ai-policy',    phase: 1 },
      { id: 'S2', label: '2. Risk Tiering', slug: '02-risk-tiering', phase: 1 },
      { id: 'S3', label: '3. Risk Check',   slug: '03-risk-check',   phase: 1 },
    ],
  },
  {
    num: 2,
    title: 'Make it legal & safe',
    tagline: 'Meet the laws, vet your suppliers, protect your data.',
    stages: [
      { id: 'S4', label: '4. Compliance',          slug: '04-compliance',       phase: 2 },
      { id: 'S5', label: '5. Third-party AI Risk', slug: '05-third-party-risk', phase: 2 },
      { id: 'S6', label: '6. Data Controls',       slug: '06-data-controls',    phase: 2 },
    ],
  },
  {
    num: 3,
    title: 'Prove it works',
    tagline: 'Stress-test the system, write down what you did, name who’s on the hook.',
    stages: [
      { id: 'S7', label: '7. Red-teaming',    slug: '07-red-teaming',    phase: 3 },
      { id: 'S8', label: '8. Documentation',  slug: '08-documentation',  phase: 3 },
      { id: 'S9', label: '9. Accountability', slug: '09-accountability', phase: 3 },
    ],
  },
  {
    num: 4,
    title: 'Run and watch',
    tagline: 'Supervise live AI, handle incidents, keep an eye on it forever.',
    stages: [
      { id: 'S10', label: '10. Agentic Oversight',  slug: '10-agentic-oversight', phase: 4 },
      { id: 'S11', label: '11. Incident Response',  slug: '11-incident-response', phase: 4 },
      { id: 'S12', label: '12. Monitoring',         slug: '12-monitoring',        phase: 4 },
    ],
  },
];

const wrapperClass = ['journey-board', currentStage ? `current-S${currentStage}` : ''].filter(Boolean).join(' ');
---
<nav class={wrapperClass} aria-label="The 12-stage AI governance journey">
  {phases.map((p, idx) => {
    const isLast = idx === phases.length - 1;
    return (
      <section class={`journey-phase journey-phase-${p.num}`}>
        <header class="journey-phase-head">
          <span class="journey-phase-num">Phase {p.num}</span>
          <h3 class="journey-phase-title">{p.title}</h3>
          <p class="journey-phase-tag">{p.tagline}</p>
        </header>
        <ol class="journey-stages">
          {p.stages.map((s, sidx) => {
            const n = parseInt(s.id.slice(1), 10);
            const isHere = currentStage === n;
            const showArrow = sidx < p.stages.length - 1;
            return (
              <>
                <li class={isHere ? 'journey-stage current' : 'journey-stage'}>
                  <a href={withBase(BASE, `/stages/${s.slug}/`)} class="journey-stage-link">
                    <span class="journey-stage-num">{n}</span>
                    <span class="journey-stage-label">{s.label.replace(/^\d+\.\s*/, '')}</span>
                  </a>
                  {isHere && <span class="journey-here">you are here</span>}
                </li>
                {showArrow && <li aria-hidden="true" class="journey-arrow">→</li>}
              </>
            );
          })}
        </ol>
        {!isLast && <div aria-hidden="true" class="journey-phase-arrow">↓</div>}
      </section>
    );
  })}
</nav>

<style>
  .journey-board {
    display: grid;
    gap: 14px;
    margin: 20px 0 24px;
  }
  .journey-phase {
    background: var(--sl-color-bg-sidebar);
    border-radius: 12px;
    padding: 14px 16px 18px;
    border-left: 4px solid var(--sl-color-accent);
    position: relative;
  }
  .journey-phase-1 { border-left-color: #6366f1; }
  .journey-phase-2 { border-left-color: #0891b2; }
  .journey-phase-3 { border-left-color: #16a34a; }
  .journey-phase-4 { border-left-color: #d97706; }

  .journey-phase-head {
    margin-bottom: 12px;
  }
  .journey-phase-num {
    display: inline-block;
    font-family: var(--font-mono, ui-monospace);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 8px;
    border-radius: 999px;
    border: 1px solid var(--sl-color-accent);
    color: var(--sl-color-accent);
    background: var(--sl-color-bg);
  }
  .journey-phase-1 .journey-phase-num { color: #6366f1; border-color: #6366f1; }
  .journey-phase-2 .journey-phase-num { color: #0891b2; border-color: #0891b2; }
  .journey-phase-3 .journey-phase-num { color: #16a34a; border-color: #16a34a; }
  .journey-phase-4 .journey-phase-num { color: #d97706; border-color: #d97706; }

  .journey-phase-title {
    margin: 6px 0 2px;
    font-size: 1.15rem;
    font-weight: 700;
  }
  .journey-phase-tag {
    margin: 0;
    font-size: 0.92rem;
    font-style: italic;
    color: var(--sl-color-text-muted);
  }

  .journey-stages {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 8px;
  }
  .journey-stage {
    flex: 1 1 220px;
    min-width: 0;
  }
  .journey-stage-link {
    display: flex;
    gap: 10px;
    align-items: center;
    padding: 10px 12px;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    text-decoration: none;
    color: var(--sl-color-text);
    transition: border-color 0.15s ease, transform 0.15s ease;
    height: 100%;
  }
  .journey-stage-link:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-1px);
  }
  .journey-stage-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: var(--sl-color-bg-sidebar);
    font-family: var(--font-mono, ui-monospace);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--sl-color-text-muted);
    flex: 0 0 auto;
  }
  .journey-stage-label {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.25;
  }
  .journey-stage.current .journey-stage-link {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }
  .journey-stage.current .journey-stage-num {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }
  .journey-here {
    display: inline-block;
    margin-top: 4px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-accent);
  }
  .journey-arrow {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    color: var(--sl-color-text-muted);
    font-size: 1rem;
    user-select: none;
  }
  @media (max-width: 36em) {
    .journey-arrow { display: none; }
    .journey-stages { gap: 6px; }
  }

  .journey-phase-arrow {
    position: absolute;
    left: 50%;
    bottom: -18px;
    transform: translateX(-50%);
    width: 28px;
    height: 28px;
    line-height: 28px;
    text-align: center;
    border-radius: 50%;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline);
    color: var(--sl-color-text-muted);
    font-weight: 700;
    z-index: 2;
  }
</style>
