---
interface Props {
  currentStage?: number;
}
const { currentStage } = Astro.props as Props;
const wrapperClass = ['mermaid-journey', currentStage ? `current-S${currentStage}` : ''].filter(Boolean).join(' ');

// Canonical (label, slug) pairs — slug must match the MDX filename under apps/site/src/content/docs/stages/.
const stages: Array<{ label: string; slug: string }> = [
  { label: '1. AI Policy',              slug: '01-ai-policy' },
  { label: '2. Risk Tiering',           slug: '02-risk-tiering' },
  { label: '3. Risk Check',             slug: '03-risk-check' },
  { label: '4. Compliance',             slug: '04-compliance' },
  { label: '5. Third-party AI Risk',    slug: '05-third-party-risk' },
  { label: '6. Data Controls',          slug: '06-data-controls' },
  { label: '7. Continuous Red-teaming', slug: '07-red-teaming' },
  { label: '8. Documentation',          slug: '08-documentation' },
  { label: '9. Accountability',         slug: '09-accountability' },
  { label: '10. Agentic AI Oversight',  slug: '10-agentic-oversight' },
  { label: '11. Incident Response',     slug: '11-incident-response' },
  { label: '12. Monitoring',            slug: '12-monitoring' },
];
---
<div class={wrapperClass}>

```mermaid
flowchart LR
  S1[1. AI Policy] --> S2[2. Risk Tiering] --> S3[3. Risk Check] --> S4[4. Compliance]
  S4 --> S5[5. Third-party AI Risk] --> S6[6. Data Controls] --> S7[7. Continuous Red-teaming]
  S7 --> S8[8. Documentation] --> S9[9. Accountability] --> S10[10. Agentic AI Oversight]
  S10 --> S11[11. Incident Response] --> S12[12. Monitoring]
```

  <details class="mermaid-fallback">
    <summary>List view of the 12-stage journey</summary>
    <ol>
      {stages.map((s) => (
        <li><a href={`/stages/${s.slug}/`}>{s.label}</a></li>
      ))}
    </ol>
  </details>
</div>

<style>
  .mermaid-journey :global(svg) { max-width: 100%; height: auto; }
  .mermaid-fallback {
    margin-top: 12px;
    font-size: 14px;
    color: var(--sl-color-text-muted);
  }
  .mermaid-fallback ol { padding-left: 20px; }
</style>
